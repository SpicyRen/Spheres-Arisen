					<Item class="LocalScript" referent="RBX711A23FA01F44A2ABC3BF9D8C26972AE">
						<Properties>
							<ProtectedString name="Source"><![CDATA[local replicatedStorage = game:GetService("ReplicatedStorage")
local shopfunction = replicatedStorage:WaitForChild("ShopFunction")
local button = script.Parent
local function updateButtonText()
	local _, priceOrStatus = shopfunction:InvokeServer("GetPrice")
	if priceOrStatus == "MAX" then 
		button.Text = "You're too fast..."
	else
		button.Text = "(" .. tostring(priceOrStatus) .. " Souls)"
	end
end
task.spawn(updateButtonText)
button.MouseButton1Click:Connect(function()
	button.Active = false
	local success, result = shopfunction:InvokeServer("BuySpeed")
	if success then
		button.Text = "boom"
		task.wait(0.5)
		if result == "MAX" then
			button.Text = "You're too fast..."
		else
			button.Text = "(" .. tostring(result) .. " Souls)"
			button.Active = true
		end
	else
		button.Text = result
		button.TextColor3 = Color3.fromRGB(255, 0, 0)
		task.wait(1.5)
		button.TextColor3 = Color3.fromRGB(255, 255, 255)
		updateButtonText()
		if result ~= "You're too fast..." then
			button.Active = true
		end
	end
end)]]></ProtectedString>
