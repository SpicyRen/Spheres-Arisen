			<Item class="LocalScript" referent="RBXDDD9999FFA0D4D73BA41B78DBE7FD3F2">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local players =  game:GetService("Players")
local localplayer = players.LocalPlayer
local shopframe = script.Parent:WaitForChild("ShopFrame")
local shoppart = workspace:WaitForChild("Shoppy")
local prompt = shoppart:WaitForChild("ProximityPrompt")
prompt.Triggered:Connect(function(player)
	if player == localplayer then
		shopframe.Visible = true
	end
end)]]></ProtectedString>
