		<Item class="Script" referent="RBX8330FF0B5E8C4CAAA32E45F022C25988">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local enemytemp = ReplicatedStorage:WaitForChild("Spherey")
local spawnrate = 3
local maxenemies = 60
local enemyspeed = 30
local detectrange = 500
local basesize = 1
local maxsize = 4.5
local basehealth = 100
local currentenemynum = 0
local sizetable = {
	{Name = "Small", MinScale = 0.8, MaxScale = 1.2, Weight = 70},
	{Name = "Medium", MinScale = 1.5, MaxScale = 2.2, Weight = 22},
	{Name = "Largo", MinScale = 2.5, MaxScale = 3.5, Weight = 7},
	{Name = "Titanio", MinScale = 4.0, MaxScale = maxsize, Weight = 1}
}
local function findNearest(enemyPos)
	local nearest = nil
	local shortestDist = detectrange
	for _, player in ipairs(Players:GetPlayers()) do
		local char = player.Character
		if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChildOfClass("Humanoid") then
			local dist = (char.HumanoidRootPart.Position - enemyPos).Magnitude
			if dist < shortestDist then
				shortestDist = dist
				nearest = char
			end
		end
	end
	return nearest
end
local function controlenemyAI(enemy)
	local mainpart = enemy:FindFirstChild("HumanoidRootPart")
	local humanoid = enemy:FindFirstChildOfClass("Humanoid")
	if not mainpart or not humanoid then return end
	humanoid.WalkSpeed = enemyspeed
	local attachment = Instance.new("Attachment")
	attachment.Parent = mainpart
	local alignOrientation = Instance.new("AlignOrientation")
	alignOrientation.Mode = Enum.OrientationAlignmentMode.OneAttachment
	alignOrientation.Attachment0 = attachment
	alignOrientation.MaxTorque = math.huge
	alignOrientation.Responsiveness = 200
	alignOrientation.Parent = mainpart
	local aiConnection 
	aiConnection = RunService.Heartbeat:Connect(function()
		if not enemy.Parent or humanoid.Health <= 0 then
			aiConnection:Disconnect()
			alignOrientation:Destroy()
			attachment:Destroy()
			local deatheffect = Instance.new("Sound")
			deatheffect.SoundId = "rbxassetid://4692687595"
			deatheffect.Volume = 1
			deatheffect.Parent = mainpart
			deatheffect:Play()
			local rewardval = math.floor(humanoid.MaxHealth/ 10)
			local money = Instance.new("Part")
			money.Name = "loot"
			money.Shape = Enum.PartType.Block
			money.Size = Vector3.new(1, 0.5, 1)
			money.BrickColor = BrickColor.new("New Yeller")
			money.Position = mainpart.Position
			money.Anchored = false
			money.CanCollide = true
			money.Parent = workspace
			local collected = false
			money.Touched:Connect(function(hit)
				if collected then return end
				local character = hit.Parent
				local player = Players:GetPlayerFromCharacter(character)
				if player and player:FindFirstChild("leaderstats") then
					collected = true
					player.leaderstats.Souls.Value = player.leaderstats.Souls.Value + rewardval
					money:Destroy()
				end
			end)
			task.delay(20,function()
				if money and money.parent then
					money:Destroy()
				end
			end)
			task.wait(2)
			enemy:Destroy()
			currentenemynum = math.max(0, currentenemynum - 1)
			return
		end
		local target = findNearest(mainpart.Position)
		if target then 
			local targetPos = target.HumanoidRootPart.Position
			humanoid:MoveTo(targetPos)
			if (targetPos - mainpart.Position).Magnitude > 0.1 then
				alignOrientation.CFrame = CFrame.lookAt(mainpart.Position, targetPos) * CFrame.Angles(0, math.rad(90), 0)
			end
		else
			local centerPos = Vector3.new(0, 0, 0)
			humanoid:MoveTo(centerPos)
			if (centerPos - mainpart.Position).Magnitude > 0.1 then
				alignOrientation.CFrame = CFrame.lookAt(mainpart.Position, centerPos) * CFrame.Angles(0, math.rad(90), 0)
			end
		end
	end)
	mainpart.Touched:Connect(function(hit)
		local character = hit.Parent
		if character and character:FindFirstChildOfClass("Humanoid") then
			if Players:GetPlayerFromCharacter(character) then
				character:FindFirstChildOfClass("Humanoid"):TakeDamage(20)
			end
		end 
	end)
end
local function getWeightedRandomScale()
	local totalWeight = 0
	for _, tier in ipairs(sizetable) do
		totalWeight = totalWeight + tier.Weight
	end
	local roll = math.random(1, totalWeight)
	local counter = 0
	for _, tier in ipairs(sizetable) do
		counter = counter + tier.Weight
		if roll <= counter then
			return math.random(tier.MinScale * 10, tier.MaxScale * 10)/10
		end
	end
	return basesize
end
while true do
	task.wait(spawnrate)
	if currentenemynum < maxenemies then
		local newEnemy = enemytemp:Clone()
		local chosenscale = getWeightedRandomScale()
		newEnemy:ScaleTo(chosenscale)
		local humanoid = newEnemy:FindFirstChildOfClass("Humanoid")
		if humanoid then
			local calculatedhealth = basehealth * (chosenscale ^ 1.5)
			humanoid.MaxHealth = calculatedhealth
			humanoid.Health = calculatedhealth
			newEnemy.Name = "Demon"
		end
		newEnemy.PrimaryPart.CollisionGroup = "Demon"
		local randomAngle = math.random() * math.pi * 2
		local randomDistance = math.random(80, 200)
		local randomX = math.cos(randomAngle) * randomDistance
		local randomZ = math.sin(randomAngle) * randomDistance
		if newEnemy.PrimaryPart then
			newEnemy:SetPrimaryPartCFrame(CFrame.new(randomX, 65, randomZ))
		else
			newEnemy:PivotTo(CFrame.new(randomX, 65, randomZ))
		end
		newEnemy.Parent = workspace
		currentenemynum = currentenemynum + 1
		task.spawn(controlenemyAI, newEnemy)
	end
end]]></ProtectedString>
				<bool name="Disabled">false</bool>
