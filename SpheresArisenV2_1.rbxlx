		<Item class="Script" referent="RBX5D6E2F89DCAB4AC688198012BB282B02">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UpdateTimerEvent = ReplicatedStorage:WaitForChild("UpdateTimerEvent")
local roundtime = 60
local meteors = 30
local spawndistance = 160

local function spawnMeteors()
	print ("THE WORLD IS ENDING!!!")
	for i = 1, meteors do 
		local meteor = Instance.new("Part")
		meteor.Shape = Enum.PartType.Ball
		meteor.Size = Vector3.new(14, 14, 14)
		meteor.Material = Enum.Material.Mud
		meteor.BrickColor = BrickColor.new("Bright orange")
		local randomX = math.random(-spawndistance, spawndistance)
		local randomZ = math.random(-spawndistance, spawndistance)
		meteor.Position = Vector3.new(randomX, 150, randomZ)
		meteor.AssemblyLinearVelocity = Vector3.new(math.random(-20,20), -100, math.random(-20,20))
		meteor.Parent = workspace
		local contact
		contact = meteor.Touched:Connect(function(hit)
			if hit:IsDescendantOf(meteor) then return end
			contact:Disconnect()
			local explosion = Instance.new("Explosion")
			explosion.Position = meteor.Position
			explosion.BlastRadius = 15
			explosion.DestroyJointRadiusPercent = 0
			explosion.Parent = workspace
			explosion.Hit:Connect(function(part)
				local humanoid = part.Parent:FindFirstChildOfClass("Humanoid")
				if humanoid then
					humanoid:TakeDamage(50)
				end
			end)
			meteor:Destroy()	
		end)
		task.wait(0.4)
	end
	task.wait(2)
	print ("the world is still ending but less")
end
while true do
	for timeLeft = roundtime, 0, -1 do
		UpdateTimerEvent:FireAllClients(timeLeft)
		task.wait(1)
	end
	UpdateTimerEvent:FireAllClients("THE WORLD IS ENDING!!!")
	task.wait(3)
	UpdateTimerEvent:FireAllClients("THE HUMANITY!!!")
	spawnMeteors()
end]]></ProtectedString>
