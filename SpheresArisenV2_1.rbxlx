		<Item class="Script" referent="RBX4CBB6432E8B74D579A15E9D374355FD2">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local whitelisted = {
	"ii_rendigo"
}

Players.PlayerAdded:Connect(function(player)
	player.Chatted:Connect(function(message)
		local args = string.split(message, " ")
		local command = string.lower(args[1])
		if command == "/souls" then
				if table.find(whitelisted, string.lower(player.Name)) then
					local targetname = args[2]
					local amtstring = args[3]
					if targetname and amtstring then
						local amt = tonumber(amtstring)
						if amt then
							local targetplayer = nil
							for _, p in pairs(Players:GetPlayers()) do
								if string.lower(p.Name) == string.lower(targetname) then
									targetplayer = p
									break
								end
							end
							if targetplayer then
								local leaderstats = targetplayer:FindFirstChild("leaderstats")
								local souls = leaderstats and leaderstats:FindFirstChild("Souls")
								if souls then
									souls.Value = amt
								end
							end
						end
					end
				end
		end
	end)
end)
	
		
		]]></ProtectedString>
