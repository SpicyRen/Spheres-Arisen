			<int64 name="SourceAssetId">-1</int64>
			<SharedString name="Tags">yuZpQdnvvUBOTYh1jqZ2cA==</SharedString>
			<UniqueId name="UniqueId">208d1340d194c9b30a5cd0e90000039d</UniqueId>
		</Properties>
		<Item class="Script" referent="RBX165E32894F1244D9ACD814A68E05568C">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local RocketEvent = ReplicatedStorage:WaitForChild("RocketEvent")
local speedy = 180
local boomy = 12
local hurty = 999999

RocketEvent.OnServerEvent:Connect(function(player, targetPos)
	local character = player.Character
	if not character or not character:FindFirstChild("HumanoidRootPart") then return end 
	
	local projectile = Instance.new("Part")
	projectile.Size = Vector3.new(1.5, 1.5, 1.5)
	projectile.Shape = Enum.PartType.Ball
	projectile.BrickColor = BrickColor.new("Crimson")
	projectile.Material = Enum.Material.Rock
	projectile.CanCollide = false
	
	local fire = Instance.new("Fire")
	fire.Size = 5
	fire.Parent = projectile
	
	local spawnPos = character.HumanoidRootPart.Position + (character.HumanoidRootPart.CFrame.LookVector * 4)
	projectile.Position = spawnPos
	projectile.CFrame = CFrame.lookAt(spawnPos, targetPos)
	projectile.Parent = workspace
	local attachment = Instance.new("Attachment")
	attachment.Parent = projectile
	local linearVelocity = Instance.new("LinearVelocity")
	linearVelocity.MaxForce = math.huge
	linearVelocity.VectorVelocity = projectile.CFrame.LookVector * speedy
	linearVelocity.Attachment0 = attachment
	linearVelocity.Parent = projectile
	local contact 
	contact = projectile.Touched:Connect(function(hit)
		if hit:IsDescendantOf (character) then return end
		contact:Disconnect()
		local explosion = Instance.new("Explosion")
		explosion.Position = projectile.Position
		explosion.BlastRadius = boomy
		explosion.BlastPressure = 0
		explosion.DestroyJointRadiusPercent = 0
		explosion.Parent = workspace
		explosion.Hit:Connect(function(part, distance)
			local hitCharacter = part.Parent
			local targetChar = hitCharacter:FindFirstChildOfClass("Humanoid")
			if targetChar then
				local hitPlayer = Players:GetPlayerFromCharacter(hitCharacter)
				if not hitPlayer then 
					targetChar:TakeDamage(hurty)
				end
			end
		end)
		projectile:Destroy()
	
	end)
	task.delay(4, function()
		if projectile and projectile.Parent then
				projectile:Destroy()
		end
	end)
end)]]></ProtectedString>
