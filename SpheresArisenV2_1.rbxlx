				<bool name="DefinesCapabilities">false</bool>
				<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
				<string name="Name">leaderstats</string>
				<int64 name="SourceAssetId">-1</int64>
				<SharedString name="Tags">yuZpQdnvvUBOTYh1jqZ2cA==</SharedString>
				<UniqueId name="UniqueId">14197842eabfbac10a5f3cf200001ce6</UniqueId>
			</Properties>
		</Item>
		<Item class="Script" referent="RBX7E26E227B346404E8A894F66D6C2EBD2">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local replicatedStorage = game:GetService("ReplicatedStorage")
local shopfunction = replicatedStorage:WaitForChild("ShopFunction")
local basecost = 40
local maxlvl = 46
local function getUpgradeStats(player)
	local currentlvl = player:GetAttribute("SpeedLevel") or 0
	local currentcost = basecost * math.pow(2, currentlvl)
	local nextspeed = 24 + ((currentlvl + 1) * 6)
	return currentlvl, currentcost, nextspeed
end
shopfunction.OnServerInvoke = function(player, action)
	local leaderstats = player:FindFirstChild("leaderstats")
	local souls = leaderstats and leaderstats:FindFirstChild("Souls")
	local currentlvl, currentcost, nextspeed = getUpgradeStats(player)
	if action == "GetPrice" then
		if currentlvl >= maxlvl then
			return true, "max", 24 + (currentlvl * 6)
		end
		return true, currentcost, 24 + (currentlvl * 6)
	end
	if action == "BuySpeed" then
		if currentlvl >= maxlvl then
			return false, "You're too fast..."
		end
		if souls and souls.Value >= currentcost then
			local char = player.Character
			local humanoid = char and char:FindFirstChildOfClass("Humanoid")
			if humanoid then
				souls.Value = souls.Value - currentcost
				humanoid.WalkSpeed = nextspeed
				player:SetAttribute("SpeedLevel", currentlvl + 1)
				local _, newCost, _ = getUpgradeStats(player)
				if currentlvl + 1 >= maxlvl then
					return true, "max"
				else 
					return true, newCost
				end
			else
				return false, "no character"
			end
		else
			return false, "havent harvested enough souls"
		end
	end
end]]></ProtectedString>
