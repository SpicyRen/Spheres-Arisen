				<string name="Name">hordification</string>
				<int64 name="SourceAssetId">-1</int64>
				<SharedString name="Tags">yuZpQdnvvUBOTYh1jqZ2cA==</SharedString>
				<UniqueId name="UniqueId">71975cbe727b25b70a5db18300000dc1</UniqueId>
			</Properties>
