		</Item>
		<Item class="Script" referent="RBXE78134D5E1A64CDFA76970C84066BD8D">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")
local speedstore = DataStoreService:GetDataStore("PlayerSpeedData")
local function onPlayerAdded(player)
	player:SetAttribute("SpeedLevel", 0)
	player.CharacterAdded:Connect(function(character)
		local humanoid = character:WaitForChild("Humanoid")
		local currentlvl = player:GetAttribute("SpeedLevel") or 0
		local calculatedspd = 24 + (currentlvl * 6)
		humanoid.WalkSpeed = calculatedspd
	end)
	local savedlvl = 0
	local success, errormessage = pcall(function()
		savedlvl = speedstore:GetAsync(player.UserId .. "-SpeedLevel")
	end)
	if success and savedlvl then
		player:SetAttribute("SpeedLevel", savedlvl)
	end
	if player.Character then
		local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
		if humanoid then
			local currentlvl = player:GetAttribute("SpeedLevel") or 0
			humanoid.WalkSpeed = 24 + (currentlvl * 6)
		end
	end
end
Players.PlayerAdded:Connect(onPlayerAdded)
for _, player in Players:GetPlayers() do
	onPlayerAdded(player)
end
Players.PlayerRemoving:Connect(function(player)
	local currentlvl = player:GetAttribute("SpeedLevel") or 0
	local success, errormessage = pcall (function()
		speedstore:SetAsync(player.UserId .. "-SpeedLevel", currentlvl)
	end)
	if not success then
		warn ("failed to save speed data for " .. player.Name .. ": " .. errormessage)
	end
end)]]></ProtectedString>
